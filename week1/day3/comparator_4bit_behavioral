// File: comparator_4bit_behavioral.v
// Same function, using Verilog's built-in comparison operators
// A synthesis tool turns THIS into roughly the same gates as the structural version

module comparator_4bit_behavioral(
    input  wire [3:0] A,
    input  wire [3:0] B,
    output wire GT,
    output wire EQ,
    output wire LT
);
    assign GT = (A > B);
    assign EQ = (A == B);
    assign LT = (A < B);
endmodule
